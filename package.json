{
  "name": "Lull",
  "version": "1.0.7",
  "description": "Lull — ambient sound player for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mas": "electron-builder --mac mas"
  },
  "keywords": [],
  "author": "Olddsun",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3"
  },
  "build": {
    "appId": "com.olddsun.lull",
    "productName": "Lull",
    "files": [
      "**/*",
      "!node_modules/**",
      "sounds/**"
    ],
    "mac": {
      "icon": "dock-icon.png",
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "mas": {
      "entitlements": "entitlements.mas.plist",
      "entitlementsInherit": "entitlements.mas.inherit.plist",
      "hardenedRuntime": false,
      "extraResources": [
        {
          "from": "PrivacyInfo.xcprivacy",
          "to": "PrivacyInfo.xcprivacy"
        }
      ]
    }
  }
}
