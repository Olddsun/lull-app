{
  "name": "Lull",
  "version": "1.0.7",
  "description": "Lull — ambient sound player for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "Olddsun",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.olddsun.lull",
    "productName": "Lull",
    "mac": {
      "icon": "dock-icon.png",
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "**/*",
      "!node_modules/**",
      "sounds/**"
    ]
  }
}
